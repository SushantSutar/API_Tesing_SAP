{
  "welcomeFile": "/index.html",
  "authenticationMethod": "none",
  "routes": [
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "srv-api",
      "authenticationType": "none"
    },
    {
      "source": "^(.*)$",
      "localDir": "resources",
      "authenticationType": "none"
    }
  ]
}
